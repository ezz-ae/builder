# Real Estate Sites Builder - Environment Configuration
# Copy this file to .env.local and fill in your actual values
# NEVER commit .env.local to version control
# NEVER hardcode credentials in source code

# ============================================
# NEON DATABASE CONFIGURATION
# ============================================
# Your Neon PostgreSQL connection string
# Get from: https://console.neon.tech/
DATABASE_URL=postgresql://user:password@host/database?sslmode=require&channel_binding=require

# ============================================
# ENTRESTATE API CONFIGURATION
# ============================================
# Real estate market analysis API
# Get from: https://entrestate.com/api
ENTRESTATE_API_KEY=your-entrestate-api-key-here
ENTRESTATE_API_BASE_URL=https://api.entrestate.com

# ============================================
# GOOGLE VERTEX AI CONFIGURATION
# ============================================
# Google Cloud Project credentials for Gemini
# Get from: https://console.cloud.google.com/
GOOGLE_API_KEY=your-google-api-key-here
GOOGLE_PROJECT_ID=your-gcp-project-id
GOOGLE_CLOUD_CREDENTIALS=path/to/service-account-key.json

# ============================================
# APPLICATION CONFIGURATION
# ============================================
# Environment: development, staging, production
NODE_ENV=development

# API endpoint for frontend
NEXT_PUBLIC_API_URL=http://localhost:3002/api

# Port for development server
PORT=3002

# ============================================
# SECURITY
# ============================================
# Next.js secret for authentication (if implemented)
NEXTAUTH_SECRET=your-nextauth-secret-here
NEXTAUTH_URL=http://localhost:3002

# ============================================
# LOGGING & MONITORING
# ============================================
# Enable detailed logging
DEBUG=false
LOG_LEVEL=info

# ============================================
# FEATURE FLAGS
# ============================================
# Enable/disable specific features
ENABLE_AI_FEATURES=true
ENABLE_MARKET_ANALYSIS=true
ENABLE_INVESTMENT_CALC=true
